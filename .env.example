# Copy this file: cp .env.example .env
# Then edit .env with your actual values

# === PRIMARY: Groq (FREE) ===
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === OPTIONAL: Google Gemini (FREE) ===
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxx

# === OPTIONAL: Anthropic Claude (PAID) ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# === AI Provider Selection ===
# Options: "groq" | "gemini" | "anthropic" | "ollama"
AI_PROVIDER=groq

# === Groq Model Selection (all FREE) ===
# Options: llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768 | gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# === App Settings ===
MAX_FILE_SIZE_MB=50
MAX_PAGES=500
DEBUG=false

# === Observability: Langfuse (FREE - 100k traces/month) ===
# Sign up at https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_HOST="https://cloud.langfuse.com"
# Leave blank to disable cloud tracing (local analytics still works)

# === Snowflake (for test_snowflake.py / data warehouse connector) ===
SNOWFLAKE_ACCOUNT=your-account-id
SNOWFLAKE_USER=your-username
SNOWFLAKE_PASSWORD=your-password
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=SNOWFLAKE_SAMPLE_DATA
SNOWFLAKE_SCHEMA=TPCH_SF10

# === Email / SMTP Alerts ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
